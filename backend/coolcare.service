[Unit]
Description=CoolCare Backend FastAPI Service
After=network.target

[Service]
User=root
WorkingDirectory=/var/www/coolcare/backend
ExecStart=/var/www/coolcare/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
StandardOutput=append:/var/www/coolcare/logs/app.log
StandardError=append:/var/www/coolcare/logs/app.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
